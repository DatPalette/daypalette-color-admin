# 把这个文件复制为 .env.local 后，再填写你自己的真实配置。
# API Key 直接填 key 本身，不要加 "Bearer " 前缀。

# 火山引擎 Ark 图片生成配置。
# 这里填写你在火山 Ark 控制台里创建的 API Key。
VOLC_API_KEY=
# 这里填写你当前账号实际可用的图片模型 ID。
VOLC_MODEL=doubao-seedream-4-5-251128
# 一般保持默认即可，除非你自己有特殊区域节点或代理网关。
VOLC_BASE_URL=https://ark.cn-beijing.volces.com

# 阿里百炼 DashScope 图片生成配置。
# 这里填写你在 DashScope 控制台里创建的 API Key。
ALI_API_KEY=
# 这里填写你当前账号实际可用的图片模型 ID。
ALI_MODEL=qwen-image-2.0-2026-03-03
# 一般保持默认即可，除非你自己有特殊区域节点或代理网关。
ALI_BASE_URL=https://dashscope.aliyuncs.com
# 可选。只有你的 DashScope 账号明确要求 workspace ID 时才填写。
ALI_WORKSPACE_ID=

# 可选默认值。只有当 profile 没有显式覆写时，才会使用这里的配置。
# 这个尺寸格式取决于 provider，例如 2K 或 1024*1024。
DEFAULT_IMAGE_SIZE=
# 可选输出目录。相对路径会以当前 package 根目录为基准解析。
# 例如：.local/runs
DEFAULT_OUTPUT_DIR=
# 默认水印开关。只有 profile 自己没有覆写时，才会使用这里的值。
DEFAULT_WATERMARK=false