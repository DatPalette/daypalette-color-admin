# Copy this file to apps/admin-api/.env and keep only one provider block active.
# After editing, restart admin-api.

# --- Xiaomi Mimo example ---
DAYPALETTE_LLM_API_KEY=your_mimo_api_key_here
DAYPALETTE_LLM_MODEL=your_mimo_model_name_here
DAYPALETTE_LLM_BASE_URL=https://your-mimo-base-url-here

# --- Qwen example ---
# If you switch to Qwen later, replace the three lines above with the block below.
# The example below uses Alibaba DashScope's OpenAI-compatible endpoint in the Beijing region.
# DAYPALETTE_LLM_API_KEY=your_qwen_api_key_here
# DAYPALETTE_LLM_MODEL=your_qwen_model_name_here
# DAYPALETTE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
